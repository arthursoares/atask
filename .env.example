# Copy to .env and fill in values for your deployment.
# .env / .env.local are gitignored — never commit real secrets.

# ── Required ──────────────────────────────────────────────────────────────
# Directory holding both PocketBase's own data.db (auth/users/settings) and
# the domain atask.db SQLite file, side by side. Must be a persistent volume.
DATA_DIR=/app/data

# Public URL this server is reachable at. Used to build OAuth redirect URIs.
BASE_URL=https://your-server.com

# ── Auth ──────────────────────────────────────────────────────────────────
# false = invite-only (admin creates users via `atask admin create-user`)
# true  = anyone can self-register via /auth/register
REGISTRATION_OPEN=false

# ── OAuth (optional — leave empty to disable a provider) ────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Admin ─────────────────────────────────────────────────────────────────
# true = expose PocketBase's built-in /_/ admin dashboard
POCKETBASE_ADMIN_UI=false
